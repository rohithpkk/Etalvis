/*C Level 12 - Problem 2
Get a string and a character from the user,
find all the positions where the character is present, and print it.
Example:
string: helloetalvislearning
character: e
Answer: 2,6,14 */

#include <stdio.h>
int finding_no_of_letters(char n1[],char letter,int *n2);

int main() {
    int n2[20],i;
    char n1[20],letter;
    printf("Enter a string:");
    scanf("%s",n1);
    printf("Enter a letter:");
    scanf("\n%c",&letter);
    finding_no_of_letters(n1,letter,n2);
    for(i=0;n2[i]!=-1;i++){
    printf("%d,",n2[i]);
    }
    return 0;
}

int finding_no_of_letters(char n1[],char letter,int *n2){
     int i,y=0;
      for(i=0;n1[i]!=0;i++){
         if(n1[i]==letter){
             n2[y]=i+1;
             y++;
         }
      }
      n2[y]=-1;
}
